#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "$REPO_ROOT"

is_env_backup_name() {
  local name="$1"
  case "$name" in
    .env.bak|.env.bak-*|.env.bak.*|.env.backup|.env.backup-*|.env.backup.*|.env.*.bak|.env.*.bak-*|.env.*.bak.*|.env.*.backup|.env.*.backup-*|.env.*.backup.*)
      return 0
      ;;
  esac
  return 1
}

collect_env_backup_hits() {
  local mode="$1"
  local path
  if [[ "$mode" == "tracked" ]]; then
    git ls-files
  else
    git diff --cached --name-only --diff-filter=ACMR
  fi | while IFS= read -r path; do
    local bn
    bn="$(basename "$path")"
    if is_env_backup_name "$bn"; then
      echo "$path"
    fi
  done
}

mapfile -t TRACKED_HITS < <(collect_env_backup_hits tracked)
mapfile -t STAGED_HITS < <(collect_env_backup_hits staged)

if [[ ${#TRACKED_HITS[@]} -gt 0 || ${#STAGED_HITS[@]} -gt 0 ]]; then
  echo "[pre-commit] BLOCKED: .env backup artifacts detected in git state." >&2
  if [[ ${#TRACKED_HITS[@]} -gt 0 ]]; then
    echo "Tracked:" >&2
    printf '  %s\n' "${TRACKED_HITS[@]}" >&2
  fi
  if [[ ${#STAGED_HITS[@]} -gt 0 ]]; then
    echo "Staged:" >&2
    printf '  %s\n' "${STAGED_HITS[@]}" >&2
  fi
  echo "Remove these files from git and keep them ignored." >&2
  exit 1
fi

echo "[pre-commit] Running public leak check..."
bash "$REPO_ROOT/check-for-leaks.sh"

echo "[pre-commit] Running checkbox conformance check..."
DETECTOR="/root/xarta-node/.xarta/.claude/skills/web-design/scripts/detect-legacy-checkboxes.sh"
if [[ -x "$DETECTOR" ]]; then
  bash "$DETECTOR" "$REPO_ROOT/gui-fallback"
else
  echo "ERROR: checkbox detector not found at $DETECTOR" >&2
  echo "Install/update private web-design skill before committing." >&2
  exit 1
fi

echo "[pre-commit] Running delete icon conformance check..."
DELETE_DETECTOR="/root/xarta-node/.xarta/.claude/skills/web-design/scripts/detect-delete-icon-nonconformance.sh"
if [[ -x "$DELETE_DETECTOR" ]]; then
  bash "$DELETE_DETECTOR" "$REPO_ROOT/gui-fallback"
else
  echo "ERROR: delete icon detector not found at $DELETE_DETECTOR" >&2
  echo "Install/update private web-design skill before committing." >&2
  exit 1
fi

echo "[pre-commit] Running menu action order audit..."
MENU_ORDER_AUDIT="/root/xarta-node/.xarta/.claude/skills/web-design/scripts/audit-menu-action-order.sh"
if [[ -x "$MENU_ORDER_AUDIT" ]]; then
  bash "$MENU_ORDER_AUDIT" "$REPO_ROOT/gui-fallback"
else
  echo "ERROR: menu action order audit not found at $MENU_ORDER_AUDIT" >&2
  echo "Install/update private web-design skill before committing." >&2
  exit 1
fi

run_active_browser_live_checks() {
  local runner="/root/xarta-node/.xarta/.claude/skills/xarta-blueprints-browser-automation/scripts/active_browser_precommit_test.py"
  local staged_pattern='^(gui-fallback/|gui-embed/|\.githooks/pre-commit)$'

  if [[ "${XARTA_PRECOMMIT_ACTIVE_BROWSER:-0}" != "1" ]]; then
    echo "[pre-commit] Active Browser live checks disabled (set XARTA_PRECOMMIT_ACTIVE_BROWSER=1 to enable)."
    return 0
  fi

  if ! git diff --cached --name-only --diff-filter=ACMR | grep -Eq "$staged_pattern"; then
    echo "[pre-commit] No staged GUI automation files; skipping live browser checks."
    return 0
  fi

  if [[ ! -x "$runner" ]]; then
    echo "ERROR: Active Browser pre-commit runner not found at $runner" >&2
    echo "Install/update private xarta-blueprints-browser-automation skill before committing." >&2
    exit 1
  fi

  echo "[pre-commit] Running Active Browser live automation checks..."
  python3 "$runner"
}

run_active_browser_live_checks

echo "[pre-commit] OK"
